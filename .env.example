# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=0033665791697

# Admin (email qui peut accéder au panel admin)
ADMIN_EMAIL=ton@email.com
ADMIN_SECRET=change_this_secret_key_32chars_min

